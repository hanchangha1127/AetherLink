flowchart LR
    Offline["Offline authority root"] --> Authority["Allocation authority"]
    Runtime["Runtime host"] -->|"authenticated capability request"| Authority
    Client["Android client"] -->|"pair authorization through runtime channel"| Runtime
    Authority -->|"opaque pair capability"| Runtime
