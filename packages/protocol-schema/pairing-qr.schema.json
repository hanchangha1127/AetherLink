{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aetherlink.dev/schema/pairing-qr.v1.json",
  "title": "AetherLink Pairing QR Payload v1",
  "description": "Schema for the decoded aetherlink://pair query payload. This is not the runtime JSON frame protocol.",
  "type": "object",
  "allOf": [
    {
      "anyOf": [
        { "required": ["version"] },
        { "required": ["v"] }
      ]
    },
    {
      "anyOf": [
        { "required": ["pairing_nonce"] },
        { "required": ["nonce"] },
        { "required": ["n"] }
      ]
    },
    {
      "anyOf": [
        { "required": ["pairing_code"] },
        { "required": ["code"] },
        { "required": ["c"] }
      ]
    },
    {
      "anyOf": [
        { "required": ["runtime_device_id"] },
        { "required": ["mac_device_id"] },
        { "required": ["device_id"] },
        { "required": ["rid"] }
      ]
    },
    {
      "anyOf": [
        { "required": ["runtime_key_fingerprint"] },
        { "required": ["fingerprint"] },
        { "required": ["cert_fingerprint"] },
        { "required": ["rf"] }
      ]
    },
    {
      "if": {
        "required": ["relay_host"],
        "properties": {
          "relay_host": { "$ref": "#/$defs/privateOverlayRelayHost" }
        }
      },
      "then": { "$ref": "#/$defs/privateOverlayScopeRequired" }
    },
    {
      "if": {
        "required": ["remote_host"],
        "properties": {
          "remote_host": { "$ref": "#/$defs/privateOverlayRelayHost" }
        }
      },
      "then": { "$ref": "#/$defs/privateOverlayScopeRequired" }
    },
    {
      "if": {
        "required": ["route_host"],
        "properties": {
          "route_host": { "$ref": "#/$defs/privateOverlayRelayHost" }
        }
      },
      "then": { "$ref": "#/$defs/privateOverlayScopeRequired" }
    },
    {
      "if": {
        "required": ["rendezvous_host"],
        "properties": {
          "rendezvous_host": { "$ref": "#/$defs/privateOverlayRelayHost" }
        }
      },
      "then": { "$ref": "#/$defs/privateOverlayScopeRequired" }
    },
    {
      "if": {
        "required": ["rh"],
        "properties": {
          "rh": { "$ref": "#/$defs/privateOverlayRelayHost" }
        }
      },
      "then": { "$ref": "#/$defs/privateOverlayScopeRequired" }
    },
    {
      "description": "Relay route material must use one relay alias family: canonical relay_* fields, remote_* fields, route_* fields, rendezvous_* fields, or compact rh/rp/ri/rs/rx/rrn fields, not a mix.",
      "not": {
        "anyOf": [
          {
            "allOf": [
              {
                "anyOf": [
                  { "required": ["relay_host"] },
                  { "required": ["relay_port"] },
                  { "required": ["relay_id"] },
                  { "required": ["relay_secret"] },
                  { "required": ["relay_expires_at"] },
                  { "required": ["relay_nonce"] }
                ]
              },
              {
                "anyOf": [
                  { "required": ["remote_host"] },
                  { "required": ["remote_port"] },
                  { "required": ["remote_id"] },
                  { "required": ["remote_secret"] },
                  { "required": ["remote_expires_at"] },
                  { "required": ["remote_nonce"] }
                ]
              }
            ]
          },
          {
            "allOf": [
              {
                "anyOf": [
                  { "required": ["relay_host"] },
                  { "required": ["relay_port"] },
                  { "required": ["relay_id"] },
                  { "required": ["relay_secret"] },
                  { "required": ["relay_expires_at"] },
                  { "required": ["relay_nonce"] }
                ]
              },
              {
                "anyOf": [
                  { "required": ["route_host"] },
                  { "required": ["route_port"] },
                  { "required": ["route_id"] },
                  { "required": ["route_secret"] },
                  { "required": ["route_expires_at"] },
                  { "required": ["route_nonce"] }
                ]
              }
            ]
          },
          {
            "allOf": [
              {
                "anyOf": [
                  { "required": ["relay_host"] },
                  { "required": ["relay_port"] },
                  { "required": ["relay_id"] },
                  { "required": ["relay_secret"] },
                  { "required": ["relay_expires_at"] },
                  { "required": ["relay_nonce"] }
                ]
              },
              {
                "anyOf": [
                  { "required": ["rendezvous_host"] },
                  { "required": ["rendezvous_port"] },
                  { "required": ["rendezvous_id"] },
                  { "required": ["rendezvous_secret"] },
                  { "required": ["rendezvous_expires_at"] },
                  { "required": ["rendezvous_nonce"] }
                ]
              }
            ]
          },
          {
            "allOf": [
              {
                "anyOf": [
                  { "required": ["relay_host"] },
                  { "required": ["relay_port"] },
                  { "required": ["relay_id"] },
                  { "required": ["relay_secret"] },
                  { "required": ["relay_expires_at"] },
                  { "required": ["relay_nonce"] }
                ]
              },
              {
                "anyOf": [
                  { "required": ["rh"] },
                  { "required": ["rp"] },
                  { "required": ["ri"] },
                  { "required": ["rs"] },
                  { "required": ["rx"] },
                  { "required": ["rrn"] }
                ]
              }
            ]
          },
          {
            "allOf": [
              {
                "anyOf": [
                  { "required": ["remote_host"] },
                  { "required": ["remote_port"] },
                  { "required": ["remote_id"] },
                  { "required": ["remote_secret"] },
                  { "required": ["remote_expires_at"] },
                  { "required": ["remote_nonce"] }
                ]
              },
              {
                "anyOf": [
                  { "required": ["route_host"] },
                  { "required": ["route_port"] },
                  { "required": ["route_id"] },
                  { "required": ["route_secret"] },
                  { "required": ["route_expires_at"] },
                  { "required": ["route_nonce"] }
                ]
              }
            ]
          },
          {
            "allOf": [
              {
                "anyOf": [
                  { "required": ["remote_host"] },
                  { "required": ["remote_port"] },
                  { "required": ["remote_id"] },
                  { "required": ["remote_secret"] },
                  { "required": ["remote_expires_at"] },
                  { "required": ["remote_nonce"] }
                ]
              },
              {
                "anyOf": [
                  { "required": ["rendezvous_host"] },
                  { "required": ["rendezvous_port"] },
                  { "required": ["rendezvous_id"] },
                  { "required": ["rendezvous_secret"] },
                  { "required": ["rendezvous_expires_at"] },
                  { "required": ["rendezvous_nonce"] }
                ]
              }
            ]
          },
          {
            "allOf": [
              {
                "anyOf": [
                  { "required": ["remote_host"] },
                  { "required": ["remote_port"] },
                  { "required": ["remote_id"] },
                  { "required": ["remote_secret"] },
                  { "required": ["remote_expires_at"] },
                  { "required": ["remote_nonce"] }
                ]
              },
              {
                "anyOf": [
                  { "required": ["rh"] },
                  { "required": ["rp"] },
                  { "required": ["ri"] },
                  { "required": ["rs"] },
                  { "required": ["rx"] },
                  { "required": ["rrn"] }
                ]
              }
            ]
          },
          {
            "allOf": [
              {
                "anyOf": [
                  { "required": ["route_host"] },
                  { "required": ["route_port"] },
                  { "required": ["route_id"] },
                  { "required": ["route_secret"] },
                  { "required": ["route_expires_at"] },
                  { "required": ["route_nonce"] }
                ]
              },
              {
                "anyOf": [
                  { "required": ["rendezvous_host"] },
                  { "required": ["rendezvous_port"] },
                  { "required": ["rendezvous_id"] },
                  { "required": ["rendezvous_secret"] },
                  { "required": ["rendezvous_expires_at"] },
                  { "required": ["rendezvous_nonce"] }
                ]
              }
            ]
          },
          {
            "allOf": [
              {
                "anyOf": [
                  { "required": ["route_host"] },
                  { "required": ["route_port"] },
                  { "required": ["route_id"] },
                  { "required": ["route_secret"] },
                  { "required": ["route_expires_at"] },
                  { "required": ["route_nonce"] }
                ]
              },
              {
                "anyOf": [
                  { "required": ["rh"] },
                  { "required": ["rp"] },
                  { "required": ["ri"] },
                  { "required": ["rs"] },
                  { "required": ["rx"] },
                  { "required": ["rrn"] }
                ]
              }
            ]
          },
          {
            "allOf": [
              {
                "anyOf": [
                  { "required": ["rendezvous_host"] },
                  { "required": ["rendezvous_port"] },
                  { "required": ["rendezvous_id"] },
                  { "required": ["rendezvous_secret"] },
                  { "required": ["rendezvous_expires_at"] },
                  { "required": ["rendezvous_nonce"] }
                ]
              },
              {
                "anyOf": [
                  { "required": ["rh"] },
                  { "required": ["rp"] },
                  { "required": ["ri"] },
                  { "required": ["rs"] },
                  { "required": ["rx"] },
                  { "required": ["rrn"] }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "description": "P2P rendezvous route material must use either canonical p2p_* fields or compact pc/prid/peb/px/pn/pv fields, not both.",
      "not": {
        "allOf": [
          {
            "anyOf": [
              { "required": ["p2p_class"] },
              { "required": ["p2p_record_id"] },
              { "required": ["p2p_encrypted_body"] },
              { "required": ["p2p_expires_at"] },
              { "required": ["p2p_anti_replay_nonce"] },
              { "required": ["p2p_protocol_version"] }
            ]
          },
          {
            "anyOf": [
              { "required": ["pc"] },
              { "required": ["prid"] },
              { "required": ["peb"] },
              { "required": ["px"] },
              { "required": ["pn"] },
              { "required": ["pv"] }
            ]
          }
        ]
      }
    }
  ],
  "properties": {
    "version": { "const": "1" },
    "v": { "const": "1" },
    "pairing_nonce": { "$ref": "#/$defs/noWhitespaceString" },
    "nonce": { "$ref": "#/$defs/noWhitespaceString" },
    "n": { "$ref": "#/$defs/noWhitespaceString" },
    "pairing_code": {
      "type": "string",
      "pattern": "^[0-9]{6}$"
    },
    "code": {
      "type": "string",
      "pattern": "^[0-9]{6}$"
    },
    "c": {
      "type": "string",
      "pattern": "^[0-9]{6}$"
    },
    "runtime_device_id": { "$ref": "#/$defs/noWhitespaceString" },
    "mac_device_id": { "$ref": "#/$defs/noWhitespaceString" },
    "device_id": { "$ref": "#/$defs/noWhitespaceString" },
    "rid": { "$ref": "#/$defs/noWhitespaceString" },
    "runtime_name": { "$ref": "#/$defs/nonEmptyString" },
    "mac_name": { "$ref": "#/$defs/nonEmptyString" },
    "name": { "$ref": "#/$defs/nonEmptyString" },
    "rn": { "$ref": "#/$defs/nonEmptyString" },
    "runtime_public_key": { "$ref": "#/$defs/noWhitespaceString" },
    "mac_public_key": { "$ref": "#/$defs/noWhitespaceString" },
    "public_key": { "$ref": "#/$defs/noWhitespaceString" },
    "rk": { "$ref": "#/$defs/noWhitespaceString" },
    "runtime_key_fingerprint": { "$ref": "#/$defs/noWhitespaceString" },
    "fingerprint": { "$ref": "#/$defs/noWhitespaceString" },
    "cert_fingerprint": { "$ref": "#/$defs/noWhitespaceString" },
    "rf": { "$ref": "#/$defs/noWhitespaceString" },
    "route_token": { "$ref": "#/$defs/opaqueRouteValue" },
    "discovery_token": { "$ref": "#/$defs/opaqueRouteValue" },
    "rt": { "$ref": "#/$defs/opaqueRouteValue" },
    "host": {
      "description": "Development diagnostic local-direct route hint only. Product clients must not use this as the normal QR pairing route.",
      "$ref": "#/$defs/nonEmptyString"
    },
    "runtime_host": {
      "description": "Alias for diagnostic local-direct host.",
      "$ref": "#/$defs/nonEmptyString"
    },
    "h": {
      "description": "Compact alias for diagnostic local-direct host.",
      "$ref": "#/$defs/nonEmptyString"
    },
    "port": {
      "$ref": "#/$defs/portValue"
    },
    "runtime_port": {
      "$ref": "#/$defs/portValue"
    },
    "p": {
      "$ref": "#/$defs/portValue"
    },
    "relay_host": { "$ref": "#/$defs/eligibleRelayHost" },
    "remote_host": { "$ref": "#/$defs/eligibleRelayHost" },
    "route_host": { "$ref": "#/$defs/eligibleRelayHost" },
    "rendezvous_host": { "$ref": "#/$defs/eligibleRelayHost" },
    "rh": { "$ref": "#/$defs/eligibleRelayHost" },
    "relay_port": {
      "$ref": "#/$defs/portValue"
    },
    "remote_port": {
      "$ref": "#/$defs/portValue"
    },
    "route_port": {
      "$ref": "#/$defs/portValue"
    },
    "rendezvous_port": {
      "$ref": "#/$defs/portValue"
    },
    "rp": {
      "$ref": "#/$defs/portValue"
    },
    "relay_id": { "$ref": "#/$defs/opaqueRouteValue" },
    "remote_id": { "$ref": "#/$defs/opaqueRouteValue" },
    "route_id": { "$ref": "#/$defs/opaqueRouteValue" },
    "rendezvous_id": { "$ref": "#/$defs/opaqueRouteValue" },
    "network_id": { "$ref": "#/$defs/opaqueRouteValue" },
    "ri": { "$ref": "#/$defs/opaqueRouteValue" },
    "relay_secret": { "$ref": "#/$defs/opaqueRouteSecret" },
    "remote_secret": { "$ref": "#/$defs/opaqueRouteSecret" },
    "route_secret": { "$ref": "#/$defs/opaqueRouteSecret" },
    "rendezvous_secret": { "$ref": "#/$defs/opaqueRouteSecret" },
    "rs": { "$ref": "#/$defs/opaqueRouteSecret" },
    "relay_expires_at": {
      "$ref": "#/$defs/epochMillisValue"
    },
    "remote_expires_at": {
      "$ref": "#/$defs/epochMillisValue"
    },
    "route_expires_at": {
      "$ref": "#/$defs/epochMillisValue"
    },
    "rendezvous_expires_at": {
      "$ref": "#/$defs/epochMillisValue"
    },
    "rx": {
      "$ref": "#/$defs/epochMillisValue"
    },
    "relay_nonce": { "$ref": "#/$defs/opaqueRouteValue" },
    "remote_nonce": { "$ref": "#/$defs/opaqueRouteValue" },
    "route_nonce": { "$ref": "#/$defs/opaqueRouteValue" },
    "rendezvous_nonce": { "$ref": "#/$defs/opaqueRouteValue" },
    "rrn": { "$ref": "#/$defs/opaqueRouteValue" },
    "p2p_class": {
      "description": "P2P rendezvous record class. This is opaque route-preparation material, not host/port reachability or proof that NAT traversal is implemented.",
      "const": "p2p_rendezvous"
    },
    "pc": {
      "description": "Compact alias for p2p_class.",
      "const": "p2p_rendezvous"
    },
    "p2p_record_id": { "$ref": "#/$defs/opaqueRouteValue" },
    "prid": { "$ref": "#/$defs/opaqueRouteValue" },
    "p2p_encrypted_body": { "$ref": "#/$defs/opaqueRouteBody" },
    "peb": { "$ref": "#/$defs/opaqueRouteBody" },
    "p2p_expires_at": {
      "$ref": "#/$defs/epochMillisValue"
    },
    "px": {
      "$ref": "#/$defs/epochMillisValue"
    },
    "p2p_anti_replay_nonce": { "$ref": "#/$defs/opaqueRouteValue" },
    "pn": { "$ref": "#/$defs/opaqueRouteValue" },
    "p2p_protocol_version": {
      "$ref": "#/$defs/p2pProtocolVersionValue"
    },
    "pv": {
      "$ref": "#/$defs/p2pProtocolVersionValue"
    },
    "relay_scope": {
      "description": "Optional route scope. `remote` marks a normal public QR-provisioned relay route, `private_overlay` marks a user-managed VPN/tunnel/private-overlay relay route, and `usb_reverse` is debug-only for loopback relay routes through adb reverse.",
      "type": "string",
      "enum": ["remote", "private_overlay", "usb_reverse"]
    },
    "remote_scope": {
      "description": "Alias for relay_scope.",
      "type": "string",
      "enum": ["remote", "private_overlay", "usb_reverse"]
    },
    "route_scope": {
      "description": "Alias for relay_scope on route_* relay material. `local_diagnostic` is accepted only for explicit local-direct QR diagnostics; product QR pairing should use remote relay/P2P route material instead.",
      "type": "string",
      "enum": ["remote", "private_overlay", "usb_reverse", "local_diagnostic"]
    },
    "rsc": {
      "description": "Compact alias for route_scope/relay_scope.",
      "type": "string",
      "enum": ["remote", "private_overlay", "usb_reverse", "local_diagnostic"]
    },
    "service_type": { "$ref": "#/$defs/nonEmptyString" }
  },
  "dependentRequired": {
    "host": ["port"],
    "port": ["host"],
    "runtime_host": ["runtime_port"],
    "runtime_port": ["runtime_host"],
    "h": ["p"],
    "p": ["h"],
    "relay_host": ["relay_port", "relay_id", "relay_secret", "relay_expires_at", "relay_nonce"],
    "relay_port": ["relay_host", "relay_id", "relay_secret", "relay_expires_at", "relay_nonce"],
    "relay_id": ["relay_host", "relay_port", "relay_secret", "relay_expires_at", "relay_nonce"],
    "relay_secret": ["relay_host", "relay_port", "relay_id", "relay_expires_at", "relay_nonce"],
    "relay_expires_at": ["relay_host", "relay_port", "relay_id", "relay_secret", "relay_nonce"],
    "relay_nonce": ["relay_host", "relay_port", "relay_id", "relay_secret", "relay_expires_at"],
    "remote_host": ["remote_port", "remote_id", "remote_secret", "remote_expires_at", "remote_nonce"],
    "remote_port": ["remote_host", "remote_id", "remote_secret", "remote_expires_at", "remote_nonce"],
    "remote_id": ["remote_host", "remote_port", "remote_secret", "remote_expires_at", "remote_nonce"],
    "remote_secret": ["remote_host", "remote_port", "remote_id", "remote_expires_at", "remote_nonce"],
    "remote_expires_at": ["remote_host", "remote_port", "remote_id", "remote_secret", "remote_nonce"],
    "remote_nonce": ["remote_host", "remote_port", "remote_id", "remote_secret", "remote_expires_at"],
    "route_host": ["route_port", "route_id", "route_secret", "route_expires_at", "route_nonce"],
    "route_port": ["route_host", "route_id", "route_secret", "route_expires_at", "route_nonce"],
    "route_id": ["route_host", "route_port", "route_secret", "route_expires_at", "route_nonce"],
    "route_secret": ["route_host", "route_port", "route_id", "route_expires_at", "route_nonce"],
    "route_expires_at": ["route_host", "route_port", "route_id", "route_secret", "route_nonce"],
    "route_nonce": ["route_host", "route_port", "route_id", "route_secret", "route_expires_at"],
    "rendezvous_host": ["rendezvous_port", "rendezvous_id", "rendezvous_secret", "rendezvous_expires_at", "rendezvous_nonce"],
    "rendezvous_port": ["rendezvous_host", "rendezvous_id", "rendezvous_secret", "rendezvous_expires_at", "rendezvous_nonce"],
    "rendezvous_id": ["rendezvous_host", "rendezvous_port", "rendezvous_secret", "rendezvous_expires_at", "rendezvous_nonce"],
    "rendezvous_secret": ["rendezvous_host", "rendezvous_port", "rendezvous_id", "rendezvous_expires_at", "rendezvous_nonce"],
    "rendezvous_expires_at": ["rendezvous_host", "rendezvous_port", "rendezvous_id", "rendezvous_secret", "rendezvous_nonce"],
    "rendezvous_nonce": ["rendezvous_host", "rendezvous_port", "rendezvous_id", "rendezvous_secret", "rendezvous_expires_at"],
    "rh": ["rp", "ri", "rs", "rx", "rrn"],
    "rp": ["rh", "ri", "rs", "rx", "rrn"],
    "ri": ["rh", "rp", "rs", "rx", "rrn"],
    "rs": ["rh", "rp", "ri", "rx", "rrn"],
    "rx": ["rh", "rp", "ri", "rs", "rrn"],
    "rrn": ["rh", "rp", "ri", "rs", "rx"],
    "p2p_class": ["p2p_record_id", "p2p_encrypted_body", "p2p_expires_at", "p2p_anti_replay_nonce", "p2p_protocol_version"],
    "p2p_record_id": ["p2p_class", "p2p_encrypted_body", "p2p_expires_at", "p2p_anti_replay_nonce", "p2p_protocol_version"],
    "p2p_encrypted_body": ["p2p_class", "p2p_record_id", "p2p_expires_at", "p2p_anti_replay_nonce", "p2p_protocol_version"],
    "p2p_expires_at": ["p2p_class", "p2p_record_id", "p2p_encrypted_body", "p2p_anti_replay_nonce", "p2p_protocol_version"],
    "p2p_anti_replay_nonce": ["p2p_class", "p2p_record_id", "p2p_encrypted_body", "p2p_expires_at", "p2p_protocol_version"],
    "p2p_protocol_version": ["p2p_class", "p2p_record_id", "p2p_encrypted_body", "p2p_expires_at", "p2p_anti_replay_nonce"],
    "pc": ["prid", "peb", "px", "pn", "pv"],
    "prid": ["pc", "peb", "px", "pn", "pv"],
    "peb": ["pc", "prid", "px", "pn", "pv"],
    "px": ["pc", "prid", "peb", "pn", "pv"],
    "pn": ["pc", "prid", "peb", "px", "pv"],
    "pv": ["pc", "prid", "peb", "px", "pn"]
  },
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "noWhitespaceString": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\S+$"
    },
    "opaqueRouteValue": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^\\S+$"
    },
    "opaqueRouteSecret": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^\\S+$"
    },
    "opaqueRouteBody": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "pattern": "^\\S+$"
    },
    "portValue": {
      "description": "URL query values are strings after decoding; schema accepts either a typed integer or its digit string representation.",
      "anyOf": [
        {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        {
          "type": "string",
          "pattern": "^([1-9][0-9]{0,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5])$"
        }
      ]
    },
    "epochMillisValue": {
      "description": "URL query values are strings after decoding; schema accepts either a typed positive integer or its digit string representation.",
      "anyOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "pattern": "^[1-9][0-9]*$"
        }
      ]
    },
    "p2pProtocolVersionValue": {
      "description": "URL query values are strings after decoding; the current P2P rendezvous preparation contract supports protocol version 1 only.",
      "anyOf": [
        {
          "const": 1
        },
        {
          "const": "1"
        }
      ]
    },
    "eligibleRelayHost": {
      "description": "A relay host for remote QR pairing. Loopback, unspecified, mDNS-local, link-local, and multicast IP literals are rejected. CGNAT, private IPv4, and ULA IPv6 literals require explicit `relay_scope=private_overlay` in app/runtime policy because they only work when a user-managed VPN, tunnel, or private overlay makes the address reachable from both devices.",
      "allOf": [
        { "$ref": "#/$defs/nonEmptyString" },
        {
          "not": {
            "enum": [
              "localhost",
              "127.0.0.1",
              "::1",
              "[::1]",
              "0.0.0.0",
              "::",
              "[::]",
              "255.255.255.255"
            ]
          }
        },
        {
          "not": {
            "pattern": "^127\\."
          }
        },
        {
          "not": {
            "pattern": "^0\\."
          }
        },
        {
          "not": {
            "pattern": "^169\\.254\\."
          }
        },
        {
          "not": {
            "pattern": "^(22[4-9]|23[0-9]|24[0-9]|25[0-5])\\."
          }
        },
        {
          "not": {
            "pattern": "^(\\[)?fe80:"
          }
        },
        {
          "not": {
            "pattern": "(^|\\.)local$"
          }
        }
      ]
    },
    "privateOverlayRelayHost": {
      "description": "Private IPv4, CGNAT, and ULA IPv6 relay literals are only valid when the QR explicitly marks a user-managed private overlay.",
      "anyOf": [
        { "pattern": "^10\\." },
        { "pattern": "^100\\.(6[4-9]|[7-9][0-9]|1[01][0-9]|12[0-7])\\." },
        { "pattern": "^172\\.(1[6-9]|2[0-9]|3[01])\\." },
        { "pattern": "^192\\.168\\." },
        { "pattern": "^(\\[)?f[c-d]" }
      ]
    },
    "privateOverlayScopeRequired": {
      "anyOf": [
        {
          "properties": {
            "relay_scope": { "const": "private_overlay" }
          },
          "required": ["relay_scope"]
        },
        {
          "properties": {
            "remote_scope": { "const": "private_overlay" }
          },
          "required": ["remote_scope"]
        },
        {
          "properties": {
            "route_scope": { "const": "private_overlay" }
          },
          "required": ["route_scope"]
        },
        {
          "properties": {
            "rsc": { "const": "private_overlay" }
          },
          "required": ["rsc"]
        }
      ]
    }
  }
}
