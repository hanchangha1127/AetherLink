{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aetherlink.dev/schema/protocol.v1.json",
  "title": "AetherLink Protocol v1",
  "type": "object",
  "required": ["version", "type", "request_id", "timestamp", "payload"],
  "properties": {
    "version": { "const": 1 },
    "type": {
      "type": "string",
      "enum": [
        "hello",
        "auth.challenge",
        "auth.response",
        "pairing.request",
        "pairing.result",
        "runtime.health",
        "models.list",
        "models.pull",
        "models.result",
        "route.refresh",
        "chat.send",
        "chat.delta",
        "chat.done",
        "chat.cancel",
        "chat.sessions.list",
        "chat.messages.list",
        "chat.title.request",
        "chat.title.result",
        "chat.session.rename",
        "chat.session.archive",
        "chat.session.restore",
        "chat.session.delete",
        "memory.list",
        "memory.upsert",
        "memory.delete",
        "memory.summary.drafts.list",
        "memory.summary.draft.approve",
        "memory.summary.draft.dismiss",
        "error"
      ]
    },
    "request_id": { "$ref": "#/$defs/nonBlankString" },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": { "type": "object" }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "hello" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/helloPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "auth.challenge" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/authChallengePayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "auth.response" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/authResponsePayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "pairing.request" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/pairingRequestPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "pairing.result" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/pairingResultPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "runtime.health" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/runtimeHealthPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "models.list" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/modelsListPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "models.result" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/modelsResultPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "models.pull" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/modelsPullPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "route.refresh" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/routeRefreshPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "chat.send" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/chatSendPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "chat.delta" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/chatDeltaPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "chat.done" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/chatDonePayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "chat.cancel" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/chatCancelPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "chat.sessions.list" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/chatSessionsListPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "chat.messages.list" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/chatMessagesListPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "chat.title.request" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/chatTitleRequestPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "chat.title.result" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/chatTitleResultPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "chat.session.rename" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/chatSessionRenamePayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "chat.session.archive" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/chatSessionArchivePayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "chat.session.restore" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/chatSessionRestorePayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "chat.session.delete" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/chatSessionDeletePayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "memory.list" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/memoryListPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "memory.upsert" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/memoryUpsertPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "memory.delete" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/memoryDeletePayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "memory.summary.drafts.list" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/memorySummaryDraftsListPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "memory.summary.draft.approve" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/memorySummaryDraftApprovePayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "memory.summary.draft.dismiss" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/memorySummaryDraftDismissPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "error" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/errorPayload" } } }
    }
  ],
  "$defs": {
    "emptyPayload": {
      "type": "object",
      "maxProperties": 0
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "nonBlankString": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "opaqueRouteValue": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^\\S+$"
    },
    "opaqueRouteSecret": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^\\S+$"
    },
    "opaqueRouteBody": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "pattern": "^\\S+$"
    },
    "privateOverlayRelayHost": {
      "description": "Private IPv4, CGNAT, and ULA IPv6 relay literals are only valid when authenticated route refresh explicitly marks a user-managed private overlay.",
      "anyOf": [
        { "pattern": "^10\\." },
        { "pattern": "^100\\.(6[4-9]|[7-9][0-9]|1[01][0-9]|12[0-7])\\." },
        { "pattern": "^172\\.(1[6-9]|2[0-9]|3[01])\\." },
        { "pattern": "^192\\.168\\." },
        { "pattern": "^(\\[)?f[c-d]" }
      ]
    },
    "helloPayload": {
      "type": "object",
      "required": ["device_id"],
      "properties": {
        "device_id": { "$ref": "#/$defs/nonBlankString" },
        "device_name": { "$ref": "#/$defs/nonBlankString" },
        "client_capabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonBlankString" },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "authChallengePayload": {
      "type": "object",
      "required": ["device_id", "nonce"],
      "properties": {
        "device_id": { "$ref": "#/$defs/nonEmptyString" },
        "nonce": { "$ref": "#/$defs/nonEmptyString" },
        "runtime_key_fingerprint": { "$ref": "#/$defs/nonEmptyString" },
        "runtime_signature": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "authResponsePayload": {
      "oneOf": [
        {
          "type": "object",
          "required": ["device_id", "nonce", "signature"],
          "properties": {
            "device_id": { "$ref": "#/$defs/nonBlankString" },
            "nonce": { "$ref": "#/$defs/nonBlankString" },
            "signature": { "$ref": "#/$defs/nonBlankString" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["accepted", "device_id"],
          "properties": {
            "accepted": { "type": "boolean" },
            "device_id": { "$ref": "#/$defs/nonEmptyString" }
          },
          "additionalProperties": false
        }
      ]
    },
    "pairingRequestPayload": {
      "type": "object",
      "required": ["pairing_nonce", "pairing_code", "device_id", "device_name", "public_key"],
      "properties": {
        "pairing_nonce": { "$ref": "#/$defs/nonBlankString" },
        "pairing_code": { "$ref": "#/$defs/nonBlankString" },
        "device_id": { "$ref": "#/$defs/nonBlankString" },
        "device_name": { "$ref": "#/$defs/nonBlankString" },
        "public_key": { "$ref": "#/$defs/nonBlankString" }
      },
      "additionalProperties": false
    },
    "pairingResultPayload": {
      "type": "object",
      "required": ["accepted"],
      "properties": {
        "accepted": { "type": "boolean" },
        "mac_device_id": { "type": "string" },
        "runtime_device_id": { "type": "string" },
        "runtime_public_key": { "type": "string" },
        "runtime_key_fingerprint": { "type": "string" },
        "trusted_device_id": { "type": "string" },
        "message": { "type": "string" },
        "code": { "type": "string" },
        "retryable": { "type": "boolean" },
        "failed_attempts": { "type": "number", "minimum": 0 },
        "max_failed_attempts": { "type": "number", "minimum": 0 },
        "remaining_attempts": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "backendHealth": {
      "type": "object",
      "required": ["available"],
      "properties": {
        "available": { "type": "boolean" },
        "message": { "type": "string" },
        "code": { "type": "string" },
        "retryable": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "modelResidencyHealth": {
      "type": "object",
      "required": ["supported", "in_flight_generations"],
      "properties": {
        "supported": { "type": "boolean" },
        "active_provider": { "enum": ["ollama", "lm_studio"] },
        "active_model_id": { "$ref": "#/$defs/nonEmptyString" },
        "in_flight_generations": { "type": "integer", "minimum": 0 },
        "idle_unload_delay_seconds": { "type": "integer", "minimum": 0 },
        "last_unload_failure": { "$ref": "#/$defs/modelResidencyUnloadFailure" }
      },
      "additionalProperties": false
    },
    "modelResidencyUnloadFailure": {
      "type": "object",
      "required": ["provider", "model_id", "reason"],
      "properties": {
        "provider": { "enum": ["ollama", "lm_studio"] },
        "model_id": { "$ref": "#/$defs/nonEmptyString" },
        "reason": { "enum": ["model_switch", "idle_timeout", "manual"] }
      },
      "additionalProperties": false
    },
    "runtimeHealthPayload": {
      "oneOf": [
        { "$ref": "#/$defs/emptyPayload" },
        {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": { "enum": ["ok", "degraded", "unavailable"] },
            "ollama": { "$ref": "#/$defs/backendHealth" },
            "lm_studio": { "$ref": "#/$defs/backendHealth" },
            "model_residency": { "$ref": "#/$defs/modelResidencyHealth" }
          },
          "additionalProperties": false
        }
      ]
    },
    "modelInfo": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "backend": { "enum": ["ollama", "lm_studio"] },
        "provider": { "enum": ["ollama", "lm_studio"] },
        "provider_model_id": { "type": "string" },
        "qualified_id": { "type": "string" },
        "model_kind": { "enum": ["chat", "embedding"] },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "context_window_tokens": { "type": "integer", "minimum": 1 },
        "modified_at": { "type": "string", "format": "date-time" },
        "installed": { "type": "boolean" },
        "running": { "type": "boolean" },
        "source": { "enum": ["local", "cloud"] },
        "remote_model": { "type": "string" }
      },
      "additionalProperties": false
    },
    "modelsListPayload": {
      "oneOf": [
        { "$ref": "#/$defs/emptyPayload" },
        { "$ref": "#/$defs/modelsResultPayload" }
      ]
    },
    "modelsResultPayload": {
      "type": "object",
      "required": ["models"],
      "properties": {
        "models": {
          "type": "array",
          "items": { "$ref": "#/$defs/modelInfo" }
        }
      },
      "additionalProperties": false
    },
    "modelsPullPayload": {
      "oneOf": [
        {
          "type": "object",
          "required": ["model"],
          "properties": {
            "model": { "$ref": "#/$defs/nonBlankString" },
            "backend": { "enum": ["ollama"] }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["model", "status"],
          "properties": {
            "model": { "$ref": "#/$defs/nonEmptyString" },
            "backend": { "enum": ["ollama"] },
            "provider": { "enum": ["ollama"] },
            "status": { "enum": ["success", "failed"] },
            "installed": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      ]
    },
    "routeRefreshPayload": {
      "oneOf": [
        { "$ref": "#/$defs/emptyPayload" },
        {
          "type": "object",
          "required": [
            "runtime_device_id",
            "runtime_key_fingerprint"
          ],
          "allOf": [
            {
              "if": {
                "properties": {
                  "relay_host": { "$ref": "#/$defs/privateOverlayRelayHost" }
                },
                "required": ["relay_host"]
              },
              "then": {
                "properties": {
                  "relay_scope": { "const": "private_overlay" }
                },
                "required": ["relay_scope"]
              }
            }
          ],
          "anyOf": [
            {
              "required": [
                "relay_host",
                "relay_port",
                "relay_id",
                "relay_secret",
                "relay_expires_at",
                "relay_nonce"
              ]
            },
            {
              "required": [
                "p2p_class",
                "p2p_record_id",
                "p2p_encrypted_body",
                "p2p_expires_at",
                "p2p_anti_replay_nonce",
                "p2p_protocol_version"
              ]
            }
          ],
          "dependentRequired": {
            "relay_host": ["relay_port", "relay_id", "relay_secret", "relay_expires_at", "relay_nonce"],
            "relay_port": ["relay_host", "relay_id", "relay_secret", "relay_expires_at", "relay_nonce"],
            "relay_id": ["relay_host", "relay_port", "relay_secret", "relay_expires_at", "relay_nonce"],
            "relay_secret": ["relay_host", "relay_port", "relay_id", "relay_expires_at", "relay_nonce"],
            "relay_expires_at": ["relay_host", "relay_port", "relay_id", "relay_secret", "relay_nonce"],
            "relay_nonce": ["relay_host", "relay_port", "relay_id", "relay_secret", "relay_expires_at"],
            "relay_scope": ["relay_host", "relay_port", "relay_id", "relay_secret", "relay_expires_at", "relay_nonce"],
            "p2p_class": ["p2p_record_id", "p2p_encrypted_body", "p2p_expires_at", "p2p_anti_replay_nonce", "p2p_protocol_version"],
            "p2p_record_id": ["p2p_class", "p2p_encrypted_body", "p2p_expires_at", "p2p_anti_replay_nonce", "p2p_protocol_version"],
            "p2p_encrypted_body": ["p2p_class", "p2p_record_id", "p2p_expires_at", "p2p_anti_replay_nonce", "p2p_protocol_version"],
            "p2p_expires_at": ["p2p_class", "p2p_record_id", "p2p_encrypted_body", "p2p_anti_replay_nonce", "p2p_protocol_version"],
            "p2p_anti_replay_nonce": ["p2p_class", "p2p_record_id", "p2p_encrypted_body", "p2p_expires_at", "p2p_protocol_version"],
            "p2p_protocol_version": ["p2p_class", "p2p_record_id", "p2p_encrypted_body", "p2p_expires_at", "p2p_anti_replay_nonce"]
          },
          "properties": {
            "runtime_device_id": { "$ref": "#/$defs/nonEmptyString" },
            "runtime_key_fingerprint": { "$ref": "#/$defs/nonEmptyString" },
            "relay_host": { "$ref": "#/$defs/nonEmptyString" },
            "relay_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "relay_id": { "$ref": "#/$defs/opaqueRouteValue" },
            "relay_secret": { "$ref": "#/$defs/opaqueRouteSecret" },
            "relay_expires_at": { "type": "integer", "minimum": 1 },
            "relay_nonce": { "$ref": "#/$defs/opaqueRouteValue" },
            "relay_scope": { "enum": ["remote", "private_overlay", "usb_reverse"] },
            "p2p_class": { "const": "p2p_rendezvous" },
            "p2p_record_id": { "$ref": "#/$defs/opaqueRouteValue" },
            "p2p_encrypted_body": { "$ref": "#/$defs/opaqueRouteBody" },
            "p2p_expires_at": { "type": "integer", "minimum": 1 },
            "p2p_anti_replay_nonce": { "$ref": "#/$defs/opaqueRouteValue" },
            "p2p_protocol_version": { "const": 1 }
          },
          "additionalProperties": false
        }
      ]
    },
    "chatMessage": {
      "type": "object",
      "required": ["role", "content"],
      "properties": {
        "role": { "enum": ["system", "user", "assistant"] },
        "content": { "type": "string" },
        "attachments": {
          "type": "array",
          "items": { "$ref": "#/$defs/chatAttachment" }
        }
      },
      "additionalProperties": false
    },
    "chatAttachment": {
      "type": "object",
      "required": ["type", "mime_type"],
      "properties": {
        "type": { "enum": ["image", "document", "file"] },
        "mime_type": { "$ref": "#/$defs/nonEmptyString" },
        "name": { "type": "string" },
        "data_base64": { "type": "string" },
        "text": { "type": "string" }
      },
      "additionalProperties": false
    },
    "chatSendPayload": {
      "type": "object",
      "required": ["session_id", "model", "messages"],
      "properties": {
        "session_id": { "$ref": "#/$defs/nonBlankString" },
        "model": { "$ref": "#/$defs/nonBlankString" },
        "locale": { "type": "string" },
        "messages": {
          "type": "array",
          "items": { "$ref": "#/$defs/chatMessage" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "chatDeltaPayload": {
      "type": "object",
      "properties": {
        "delta": { "type": "string" },
        "text": { "type": "string" },
        "reasoning_delta": { "type": "string" },
        "thinking_delta": { "type": "string" }
      },
      "anyOf": [
        { "required": ["delta"] },
        { "required": ["text"] },
        { "required": ["reasoning_delta"] },
        { "required": ["thinking_delta"] }
      ],
      "additionalProperties": false
    },
    "chatDonePayload": {
      "type": "object",
      "properties": {
        "finish_reason": { "enum": ["stop", "cancelled", "error"] },
        "usage": {
          "type": "object",
          "properties": {
            "input_tokens": { "type": "integer", "minimum": 0 },
            "output_tokens": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "chatCancelPayload": {
      "oneOf": [
        {
          "type": "object",
          "required": ["target_request_id"],
          "properties": {
            "target_request_id": { "$ref": "#/$defs/nonBlankString" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["target_request_id", "cancelled"],
          "properties": {
            "target_request_id": { "$ref": "#/$defs/nonBlankString" },
            "cancelled": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      ]
    },
    "chatSessionsListPayload": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "limit": { "type": "integer", "minimum": 0, "maximum": 200 },
            "include_archived": { "type": "boolean", "default": false },
            "query": { "$ref": "#/$defs/nonEmptyString" },
            "embedding_model_id": { "$ref": "#/$defs/nonEmptyString" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["sessions"],
          "properties": {
            "sessions": {
              "type": "array",
              "items": { "$ref": "#/$defs/chatSessionSummary" }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "chatSessionSummary": {
      "type": "object",
      "required": ["session_id", "title", "model", "last_activity_at", "message_count"],
      "properties": {
        "session_id": { "$ref": "#/$defs/nonEmptyString" },
        "title": { "type": "string" },
        "model": { "type": "string" },
        "last_activity_at": { "type": "string", "format": "date-time" },
        "message_count": { "type": "integer", "minimum": 0 },
        "status": { "type": "string", "enum": ["active", "archived"] },
        "archived_at": { "type": "string", "format": "date-time" },
        "last_event": {
          "type": "string",
          "enum": [
            "request",
            "assistant_delta",
            "reasoning_delta",
            "done",
            "cancelled",
            "error"
          ]
        },
        "last_finish_reason": { "type": "string" },
        "last_error_code": { "type": "string" },
        "search": { "$ref": "#/$defs/chatSessionSearch" }
      },
      "additionalProperties": false
    },
    "chatSessionSearch": {
      "type": "object",
      "required": ["rank", "snippet", "matched_fields"],
      "properties": {
        "rank": { "type": "integer", "minimum": 1 },
        "snippet": { "type": "string" },
        "matched_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "chatMessagesListPayload": {
      "oneOf": [
        {
          "type": "object",
          "required": ["session_id"],
          "properties": {
            "session_id": { "$ref": "#/$defs/nonBlankString" },
            "limit": { "type": "integer", "minimum": 0, "maximum": 500 }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["session_id", "messages"],
          "properties": {
            "session_id": { "$ref": "#/$defs/nonEmptyString" },
            "messages": {
              "type": "array",
              "items": { "$ref": "#/$defs/chatStoredMessage" }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "chatStoredMessage": {
      "type": "object",
      "required": ["role", "content"],
      "properties": {
        "role": { "type": "string" },
        "content": { "type": "string" },
        "reasoning": { "type": "string" },
        "attachments": {
          "type": "array",
          "items": { "$ref": "#/$defs/storedChatAttachment" }
        },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "storedChatAttachment": {
      "type": "object",
      "required": ["type", "mime_type"],
      "properties": {
        "type": { "enum": ["image", "document", "file"] },
        "mime_type": { "$ref": "#/$defs/nonEmptyString" },
        "name": { "type": "string" },
        "text": { "type": "string" }
      },
      "additionalProperties": false
    },
    "chatTitleRequestPayload": {
      "type": "object",
      "required": ["session_id", "model", "messages"],
      "properties": {
        "session_id": { "$ref": "#/$defs/nonBlankString" },
        "model": { "$ref": "#/$defs/nonBlankString" },
        "locale": { "type": "string" },
        "messages": {
          "type": "array",
          "items": { "$ref": "#/$defs/chatMessage" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "chatTitleResultPayload": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string" }
      },
      "additionalProperties": false
    },
    "chatSessionRenamePayload": {
      "oneOf": [
        {
          "type": "object",
          "required": ["session_id", "title"],
          "properties": {
            "session_id": { "$ref": "#/$defs/nonBlankString" },
            "title": { "$ref": "#/$defs/nonBlankString" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["session_id", "title", "renamed_at"],
          "properties": {
            "session_id": { "$ref": "#/$defs/nonEmptyString" },
            "title": { "$ref": "#/$defs/nonEmptyString" },
            "renamed_at": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        }
      ]
    },
    "chatSessionArchivePayload": {
      "oneOf": [
        { "$ref": "#/$defs/chatSessionLifecycleRequestPayload" },
        {
          "type": "object",
          "required": ["session_id", "status", "archived_at"],
          "properties": {
            "session_id": { "$ref": "#/$defs/nonEmptyString" },
            "status": { "const": "archived" },
            "archived_at": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        }
      ]
    },
    "chatSessionRestorePayload": {
      "oneOf": [
        { "$ref": "#/$defs/chatSessionLifecycleRequestPayload" },
        {
          "type": "object",
          "required": ["session_id", "status", "restored_at"],
          "properties": {
            "session_id": { "$ref": "#/$defs/nonEmptyString" },
            "status": { "const": "restored" },
            "restored_at": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        }
      ]
    },
    "chatSessionDeletePayload": {
      "oneOf": [
        { "$ref": "#/$defs/chatSessionLifecycleRequestPayload" },
        {
          "type": "object",
          "required": ["session_id", "status", "deleted_at"],
          "properties": {
            "session_id": { "$ref": "#/$defs/nonEmptyString" },
            "status": { "const": "deleted" },
            "deleted_at": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        }
      ]
    },
    "chatSessionLifecycleRequestPayload": {
      "type": "object",
      "required": ["session_id"],
      "properties": {
        "session_id": { "$ref": "#/$defs/nonBlankString" }
      },
      "additionalProperties": false
    },
    "memoryEntry": {
      "type": "object",
      "required": ["id", "content", "enabled", "created_at", "updated_at"],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "content": { "$ref": "#/$defs/nonEmptyString" },
        "enabled": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "source": { "$ref": "#/$defs/memoryEntrySource" },
        "search": { "$ref": "#/$defs/chatSessionSearch" }
      },
      "additionalProperties": false
    },
    "memoryEntrySource": {
      "type": "object",
      "required": [
        "kind",
        "draft_id",
        "summary_method",
        "session",
        "source_message_count",
        "source_range",
        "source_pointers"
      ],
      "properties": {
        "kind": { "const": "long_inactivity_summary_draft" },
        "draft_id": { "$ref": "#/$defs/nonEmptyString" },
        "summary_method": { "const": "deterministic_preview" },
        "session": { "$ref": "#/$defs/memorySummaryDraftSession" },
        "source_message_count": { "type": "integer", "minimum": 1 },
        "source_range": { "$ref": "#/$defs/nonEmptyString" },
        "source_pointers": {
          "type": "array",
          "items": { "$ref": "#/$defs/memorySummaryDraftSourcePointer" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "memoryListPayload": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "query": { "$ref": "#/$defs/nonEmptyString" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["entries"],
          "properties": {
            "entries": {
              "type": "array",
              "items": { "$ref": "#/$defs/memoryEntry" }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "memoryUpsertPayload": {
      "oneOf": [
        {
          "type": "object",
          "required": ["content"],
          "properties": {
            "id": { "$ref": "#/$defs/nonBlankString" },
            "content": { "$ref": "#/$defs/nonBlankString" },
            "enabled": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["entry"],
          "properties": {
            "entry": { "$ref": "#/$defs/memoryEntry" }
          },
          "additionalProperties": false
        }
      ]
    },
    "memoryDeletePayload": {
      "oneOf": [
        {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id": { "$ref": "#/$defs/nonBlankString" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["id", "deleted_at"],
          "properties": {
            "id": { "$ref": "#/$defs/nonEmptyString" },
            "deleted_at": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        }
      ]
    },
    "memorySummaryDraftsListPayload": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "limit": { "type": "integer", "minimum": 0, "maximum": 50 }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["drafts"],
          "properties": {
            "drafts": {
              "type": "array",
              "items": { "$ref": "#/$defs/memorySummaryDraft" }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "memorySummaryDraftApprovePayload": {
      "oneOf": [
        {
          "type": "object",
          "required": ["draft_id"],
          "properties": {
            "draft_id": { "$ref": "#/$defs/nonBlankString" },
            "content": { "$ref": "#/$defs/nonEmptyString" },
            "enabled": { "type": "boolean" },
            "expected_session_id": { "$ref": "#/$defs/nonEmptyString" },
            "expected_source_message_count": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["draft_id", "status", "entry"],
          "properties": {
            "draft_id": { "$ref": "#/$defs/nonBlankString" },
            "status": { "const": "approved" },
            "entry": { "$ref": "#/$defs/memoryEntry" }
          },
          "additionalProperties": false
        }
      ]
    },
    "memorySummaryDraftDismissPayload": {
      "oneOf": [
        {
          "type": "object",
          "required": ["draft_id"],
          "properties": {
            "draft_id": { "$ref": "#/$defs/nonBlankString" },
            "expected_session_id": { "$ref": "#/$defs/nonEmptyString" },
            "expected_source_message_count": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["draft_id", "status", "dismissed_at"],
          "properties": {
            "draft_id": { "$ref": "#/$defs/nonBlankString" },
            "status": { "const": "dismissed" },
            "dismissed_at": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        }
      ]
    },
    "memorySummaryDraft": {
      "type": "object",
      "required": [
        "id",
        "session",
        "source_message_count",
        "source_range",
        "source_pointers",
        "summary_preview"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "session": { "$ref": "#/$defs/memorySummaryDraftSession" },
        "source_message_count": { "type": "integer", "minimum": 1 },
        "source_range": { "$ref": "#/$defs/nonEmptyString" },
        "source_pointers": {
          "type": "array",
          "items": { "$ref": "#/$defs/memorySummaryDraftSourcePointer" },
          "minItems": 1
        },
        "summary_preview": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "memorySummaryDraftSession": {
      "type": "object",
      "required": [
        "session_id",
        "title",
        "model",
        "last_activity_at",
        "message_count",
        "inactive_seconds"
      ],
      "properties": {
        "session_id": { "$ref": "#/$defs/nonEmptyString" },
        "title": { "type": "string" },
        "model": { "type": "string" },
        "last_activity_at": { "type": "string", "format": "date-time" },
        "message_count": { "type": "integer", "minimum": 0 },
        "inactive_seconds": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "memorySummaryDraftSourcePointer": {
      "type": "object",
      "required": ["session_id", "message_index", "role", "excerpt"],
      "properties": {
        "session_id": { "$ref": "#/$defs/nonEmptyString" },
        "message_index": { "type": "integer", "minimum": 1 },
        "role": { "enum": ["user", "assistant"] },
        "created_at": { "type": "string", "format": "date-time" },
        "excerpt": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "errorPayload": {
      "type": "object",
      "required": ["code", "message", "retryable"],
      "properties": {
        "code": {
          "enum": [
            "unknown_message_type",
            "unexpected_message_direction",
            "invalid_payload",
            "not_connected",
            "pairing_required",
            "authentication_required",
            "authentication_failed",
            "backend_unavailable",
            "bad_backend_response",
            "no_models",
            "model_not_found",
            "model_not_installed",
            "generation_not_found",
            "generation_cancelled",
            "unsupported_operation",
            "unsupported_attachment",
            "unreadable_attachment",
            "chat_store_unavailable",
            "memory_store_unavailable",
            "memory_summary_draft_unavailable",
            "memory_summary_draft_stale",
            "transport_error",
            "internal_error"
          ]
        },
        "message": { "type": "string" },
        "retryable": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
